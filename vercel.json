{
    "functions": {
        "api/cron.ts": { "maxDuration": 120 },
        "api/admin-generate.ts": { "maxDuration": 120 }
    },
    "redirects": [
        {
            "source": "/diagnosis",
            "destination": "/tools/diagnosis",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap"
        },
        {
            "source": "/rss.xml",
            "destination": "/api/rss"
        },
        {
            "source": "/feed.xml",
            "destination": "/api/rss"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ]
}
